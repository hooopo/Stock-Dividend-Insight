<div class="bg-white rounded-lg shadow-md p-6 text-sm">
    <div class="mb-6 border-b border-gray-100 pb-4">
        <div class="flex flex-wrap justify-between items-center gap-3 mb-4">
            <h2 class="text-xl font-semibold text-gray-800 flex items-center">
                <svg class="w-6 h-6 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                <%= (@page_title || '股票概览列表') %> (<%= @total_count %>)
            </h2>
            <% if logged_in? %>
                <form method="post" action="/pools" class="flex items-center gap-2">
                    <input type="hidden" name="query" value="<%= request.query_string %>">
                    <input type="hidden" name="name" id="poolNameField" value="">
                    <input type="hidden" name="edit_pool_id" id="poolEditIdField" value="<%= @edit_pool_id %>">
                    <button type="button" id="savePoolBtn" class="px-3 py-1 rounded bg-blue-600 text-white hover:bg-blue-700 text-xs" data-mode="<%= @edit_pool_id ? 'edit' : 'new' %>" data-default-name="<%= (@edit_pool_name || '').to_s %>"><%= @edit_pool_id ? '更新股票池' : '保存为股票池' %></button>
                </form>
            <% else %>
                <a href="/login?<%= build_query(return_to: request.fullpath) %>" class="text-blue-600 hover:underline text-xs">登录后可保存股票池</a>
            <% end %>
        </div>

        <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600">
            <a href="/macro" class="text-blue-600 hover:underline">宏观指标</a>
            <span class="text-gray-300">|</span>
            <span>
                中国10年期国债收益率：
                <span class="font-semibold text-gray-800"><%= format_percent(@cn_10y&.yield_pct) %></span>
                <span class="text-gray-400">(<%= @cn_10y&.date %>)</span>
            </span>
            <span class="text-gray-300">|</span>
            <span>
                沪深300 PB百分位：
                <span class="font-semibold text-gray-800"><%= @hs300_eval&.pb_percentile.nil? ? '-' : "#{format_decimal(@hs300_eval.pb_percentile.to_f * 100.0, 2)}%" %></span>
            </span>
            <span class="text-gray-300">|</span>
            <span>
                A500 PB百分位：
                <span class="font-semibold text-gray-800"><%= @a500_eval&.pb_percentile.nil? ? '-' : "#{format_decimal(@a500_eval.pb_percentile.to_f * 100.0, 2)}%" %></span>
            </span>
        </div>

        <% if @layer_index_series && @layer_index_series.any? %>
            <div class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
                <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
                    <div class="text-xs text-gray-500">收息底仓指数点数（等权，基准 1000）</div>
                    <div class="mt-1 text-2xl font-semibold text-gray-900"><%= format_decimal(@layer_index_points, 2) %></div>
                    <div class="mt-2 flex flex-wrap gap-3 text-xs">
                        <% [[@layer_index_change_1m, '1个月'], [@layer_index_change_3m, '3个月'], [@layer_index_change_1y, '1年']].each do |v, label| %>
                            <% if v.nil? %>
                                <span class="text-gray-400"><%= label %>：-</span>
                            <% else %>
                                <% klass = v >= 0 ? 'text-red-600' : 'text-green-600' %>
                                <span class="<%= klass %>"><%= label %>：<%= format_decimal(v * 100.0, 2) %>%</span>
                            <% end %>
                        <% end %>
                    </div>
                    <div class="mt-2 text-xs text-gray-400">基准日：<%= @layer_index_base_date %></div>
                </div>
                <div class="lg:col-span-2 bg-white border border-gray-200 rounded-lg p-4">
                    <div class="text-xs text-gray-500 mb-2">指数走势图（近5年）</div>
                    <div class="h-48">
                        <canvas id="layerIndexChart"></canvas>
                    </div>
                </div>
            </div>
        <% end %>

        <% base_path = (@base_path || request.path_info || '/') %>
        <% base_params = { sort: @sort_param } %>
        <% base_params[:only_div5y] = '1' if @only_div5y %>
        <% base_params[:roe_5y_avg_ge_12] = '1' if @roe_5y_avg_ge_12 %>
        <% base_params[:roe_5y_min_ge_8] = '1' if @roe_5y_min_ge_8 %>
        <% base_params[:include_category_ids] = @include_category_ids unless @include_category_ids.empty? %>
        <% base_params[:exclude_category_ids] = @exclude_category_ids unless @exclude_category_ids.empty? %>
        <% base_params[:include_pb_levels] = @include_pb_levels unless @include_pb_levels.empty? %>
        <% base_params[:exclude_pb_levels] = @exclude_pb_levels unless @exclude_pb_levels.empty? %>
        <% base_params[:include_pb_percentile_levels] = @include_pb_percentile_levels unless @include_pb_percentile_levels.empty? %>
        <% base_params[:exclude_pb_percentile_levels] = @exclude_pb_percentile_levels unless @exclude_pb_percentile_levels.empty? %>
        <% base_params[:include_pe_levels] = @include_pe_levels unless @include_pe_levels.empty? %>
        <% base_params[:exclude_pe_levels] = @exclude_pe_levels unless @exclude_pe_levels.empty? %>
        <% base_params[:include_pe_percentile_levels] = @include_pe_percentile_levels unless @include_pe_percentile_levels.empty? %>
        <% base_params[:exclude_pe_percentile_levels] = @exclude_pe_percentile_levels unless @exclude_pe_percentile_levels.empty? %>
        <% base_params[:include_peg_levels] = @include_peg_levels unless @include_peg_levels.empty? %>
        <% base_params[:exclude_peg_levels] = @exclude_peg_levels unless @exclude_peg_levels.empty? %>
        <% base_params[:include_roe_levels] = @include_roe_levels unless @include_roe_levels.empty? %>
        <% base_params[:exclude_roe_levels] = @exclude_roe_levels unless @exclude_roe_levels.empty? %>
        <% base_params[:exclude_high_debt] = '1' if @exclude_high_debt %>
        <% if @adv_filters && @adv_filters.any? %>
            <% base_params[:adv_field] = @adv_filters.map { |x| x[:field] } %>
            <% base_params[:adv_op] = @adv_filters.map { |x| x[:op] } %>
            <% base_params[:adv_value] = @adv_filters.map { |x| x[:raw_value] } %>
        <% end %>

        <form id="filterForm" method="get" action="<%= base_path %>" class="mt-4 text-xs">
            <input type="hidden" id="sortInput" name="sort" value="<%= @sort_param %>">

            <details class="mt-4" <%= (@adv_filters && @adv_filters.any?) ? 'open' : '' %>>
                <summary class="text-gray-600 font-medium cursor-pointer select-none">
                    高级搜索 (<%= (@adv_filters || []).size %>)
                </summary>
                <div class="mt-2 p-3 bg-gray-50 border border-gray-200 rounded-lg">
                    <div class="flex flex-wrap items-center gap-2">
                        <button type="button" id="advAddRow" class="px-3 py-1 rounded bg-white text-gray-700 border border-gray-200 hover:bg-gray-50">添加条件</button>
                        <button type="button" id="advApply" class="px-3 py-1 rounded bg-blue-600 text-white hover:bg-blue-700">应用</button>
                        <a href="<%= base_path %>?<%= build_query(base_params.merge(adv_field: nil, adv_op: nil, adv_value: nil, page: nil)) %>" class="text-blue-600 hover:underline">清空高级搜索</a>
                    </div>
                    <div id="advRows" class="mt-3 space-y-2">
                        <% rows = (@adv_filters && @adv_filters.any?) ? @adv_filters : [{ field: '', op: '', raw_value: '' }] %>
                        <% rows.each do |r| %>
                            <div class="adv-row flex flex-wrap items-center gap-2">
                                <select name="adv_field[]" class="px-3 py-1 rounded bg-white text-gray-700 border border-gray-200 adv-field">
                                    <option value="">字段</option>
                                    <% (@adv_fields || []).each do |f| %>
                                        <option value="<%= f[:field] %>" data-type="<%= f[:type] %>" data-placeholder="<%= f[:placeholder] %>" <%= (r[:field].to_s == f[:field]) ? 'selected' : '' %>><%= f[:label] %></option>
                                    <% end %>
                                </select>
                                <select name="adv_op[]" class="px-3 py-1 rounded bg-white text-gray-700 border border-gray-200 adv-op">
                                    <% ops = ['>', '>=', '<', '<=', '=', '!=', 'contains', 'not_contains', 'starts_with', 'ends_with', 'is_null', 'not_null'] %>
                                    <% op_labels = { 'contains' => '包含', 'not_contains' => '不包含', 'starts_with' => '开头是', 'ends_with' => '结尾是', 'is_null' => '为空', 'not_null' => '不为空', '=' => '等于', '!=' => '不等于' } %>
                                    <option value="">条件</option>
                                    <% ops.each do |op| %>
                                        <option value="<%= op %>" <%= (r[:op].to_s == op) ? 'selected' : '' %>><%= op_labels[op] || op %></option>
                                    <% end %>
                                </select>
                                <input name="adv_value[]" value="<%= r[:raw_value].to_s %>" class="px-3 py-1 rounded bg-white text-gray-700 border border-gray-200 adv-value" placeholder="">
                                <button type="button" class="px-2 py-1 rounded bg-white text-gray-700 border border-gray-200 hover:bg-gray-50 adv-remove">移除</button>
                            </div>
                        <% end %>
                    </div>
                    <div class="mt-2 text-xs text-gray-500">同一字段可添加多次，条件会按 AND 叠加。</div>
                </div>
            </details>

            <div class="mt-4 text-gray-600 font-medium">过滤</div>
            <div class="mt-2 space-y-3">
                <div class="flex flex-wrap items-center gap-3">
                <label class="flex items-center gap-2 px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer">
                    <input type="checkbox" name="only_div5y" value="1" <%= @only_div5y ? 'checked' : '' %>>
                    <span>仅显示连续5年分红</span>
                </label>

                <label class="flex items-center gap-2 px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer">
                    <input type="checkbox" name="roe_5y_avg_ge_12" value="1" <%= @roe_5y_avg_ge_12 ? 'checked' : '' %>>
                    <span>ROE近5年均值≥12%</span>
                </label>

                <label class="flex items-center gap-2 px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer">
                    <input type="checkbox" name="roe_5y_min_ge_8" value="1" <%= @roe_5y_min_ge_8 ? 'checked' : '' %>>
                    <span>ROE近5年最低≥8%</span>
                </label>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div class="p-3 bg-blue-50 border border-blue-100 rounded-lg">
                        <div class="text-xs font-semibold text-blue-700 mb-2">选择</div>
                        <div class="flex flex-wrap items-center gap-2">
                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">分类 (<%= @include_category_ids.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% @categories.each do |cat| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="include_category_ids[]" value="<%= cat.id %>" <%= @include_category_ids.include?(cat.id) ? 'checked' : '' %>>
                                            <span><%= cat.name %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PB等级 (<%= @include_pb_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..6).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="include_pb_levels[]" value="<%= lvl %>" <%= @include_pb_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= pb_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PB分位 (<%= @include_pb_percentile_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..4).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="include_pb_percentile_levels[]" value="<%= lvl %>" <%= @include_pb_percentile_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= pb_percentile_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PE等级 (<%= @include_pe_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..7).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="include_pe_levels[]" value="<%= lvl %>" <%= @include_pe_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= pe_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PE分位 (<%= @include_pe_percentile_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..3).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="include_pe_percentile_levels[]" value="<%= lvl %>" <%= @include_pe_percentile_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= pe_percentile_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PEG等级 (<%= @include_peg_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..5).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="include_peg_levels[]" value="<%= lvl %>" <%= @include_peg_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= peg_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">ROE等级 (<%= @include_roe_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..3).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="include_roe_levels[]" value="<%= lvl %>" <%= @include_roe_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= roe_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>
                        </div>
                    </div>

                    <div class="p-3 bg-red-50 border border-red-100 rounded-lg">
                        <div class="text-xs font-semibold text-red-700 mb-2">排除</div>
                        <div class="flex flex-wrap items-center gap-2">
                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">分类 (<%= @exclude_category_ids.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% @categories.each do |cat| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="exclude_category_ids[]" value="<%= cat.id %>" <%= @exclude_category_ids.include?(cat.id) ? 'checked' : '' %>>
                                            <span><%= cat.name %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PB等级 (<%= @exclude_pb_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..6).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="exclude_pb_levels[]" value="<%= lvl %>" <%= @exclude_pb_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= pb_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PB分位 (<%= @exclude_pb_percentile_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..4).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="exclude_pb_percentile_levels[]" value="<%= lvl %>" <%= @exclude_pb_percentile_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= pb_percentile_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PE等级 (<%= @exclude_pe_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..7).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="exclude_pe_levels[]" value="<%= lvl %>" <%= @exclude_pe_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= pe_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PE分位 (<%= @exclude_pe_percentile_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..3).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="exclude_pe_percentile_levels[]" value="<%= lvl %>" <%= @exclude_pe_percentile_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= pe_percentile_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">PEG等级 (<%= @exclude_peg_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..5).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="exclude_peg_levels[]" value="<%= lvl %>" <%= @exclude_peg_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= peg_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <details class="relative">
                                <summary class="px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">ROE等级 (<%= @exclude_roe_levels.size %>)</summary>
                                <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                                    <% (1..3).each do |lvl| %>
                                        <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                            <input type="checkbox" name="exclude_roe_levels[]" value="<%= lvl %>" <%= @exclude_roe_levels.include?(lvl) ? 'checked' : '' %>>
                                            <span><%= roe_level_label(lvl) %></span>
                                        </label>
                                    <% end %>
                                </div>
                            </details>

                            <label class="flex items-center gap-2 px-3 py-1 rounded bg-white text-gray-700 hover:bg-gray-50 cursor-pointer select-none border border-gray-200">
                                <input type="checkbox" name="exclude_high_debt" value="1" <%= @exclude_high_debt ? 'checked' : '' %>>
                                <span>高负债(资产负债率&gt;60%)</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 text-gray-600 font-medium">排序</div>
            <div id="sortPalette" class="mt-2 flex flex-wrap items-center gap-2">
                <% current_sort_by_field = @sorts.to_h { |s| [s[:field], s[:order]] } %>
                <% @allowed_sort_fields.each do |f| %>
                    <% active_order = current_sort_by_field[f] %>
                    <span class="sort-palette-item inline-flex items-center px-2 py-1 rounded-full border <%= active_order ? 'bg-blue-50 text-blue-700 border-blue-200' : 'bg-white text-gray-700 border-gray-200' %>" data-field="<%= f %>" data-label="<%= sort_label(f) %>">
                        <span class="<%= active_order ? 'font-semibold' : '' %>"><%= sort_label(f) %></span>
                        <div class="flex items-center ml-2 gap-1">
                            <button type="button" class="sort-add px-2 py-0.5 rounded border <%= active_order == 'asc' ? 'bg-blue-50 text-blue-700 border-blue-200' : 'bg-white text-gray-500 border-gray-200 hover:bg-gray-50' %>" data-field="<%= f %>" data-order="asc" data-label="<%= sort_label(f) %>">↑</button>
