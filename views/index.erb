            <% adv_fields = @adv_filters.map { |x| x[:field].to_s } %>
            <% adv_ops = @adv_filters.map { |x| x[:op].to_s } %>
            <% adv_values = @adv_filters.map { |x| x[:raw_value].to_s } %>
            <% @adv_filters.each_with_index do |f, idx| %>
                <% spec = (@adv_fields || []).find { |x| x[:field].to_s == f[:field].to_s } %>
                <% field_label = spec ? spec[:label].to_s : f[:field].to_s %>
                <% op_label = { 'is_null' => '为空', 'not_null' => '不为空', 'contains' => '包含', 'not_contains' => '不包含', 'starts_with' => '开头是', 'ends_with' => '结尾是', '=' => '等于', '!=' => '不等于' }[f[:op].to_s] || f[:op].to_s %>
                <% value_label = %w[is_null not_null].include?(f[:op].to_s) ? '' : f[:raw_value].to_s %>
                <% next_fields = adv_fields.dup %>
                <% next_ops = adv_ops.dup %>
                <% next_values = adv_values.dup %>
                <% next_fields.delete_at(idx) %>
                <% next_ops.delete_at(idx) %>
                <% next_values.delete_at(idx) %>
                <span class="inline-flex items-center px-2 py-1 bg-white text-gray-700 rounded-full border border-purple-200">
                    <span class="font-semibold"><%= field_label %></span>
                    <span class="ml-1"><%= op_label %></span>
                    <% if value_label != '' %>
                        <span class="ml-1"><%= value_label %></span>
                    <% end %>
                    <a href="<%= base_path %>?<%= build_query(base_params.merge(adv_field: next_fields.any? ? next_fields : nil, adv_op: next_ops.any? ? next_ops : nil, adv_value: next_values.any? ? next_values : nil, page: nil)) %>" class="ml-2 text-purple-700 hover:text-purple-900">×</a>
                </span>
            <% end %>
        </div>
    </div>
