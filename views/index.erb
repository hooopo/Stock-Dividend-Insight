<div class="bg-white rounded-lg shadow-md p-6 text-sm">
    <div class="mb-6 border-b border-gray-100 pb-4">
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-semibold text-gray-800 flex items-center">
                <svg class="w-6 h-6 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                股票概览列表 (<%= @total_count %>)
            </h2>
        </div>

        <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600">
            <a href="/macro" class="text-blue-600 hover:underline">宏观指标</a>
            <span class="text-gray-300">|</span>
            <span>
                中国10年期国债收益率：
                <span class="font-semibold text-gray-800"><%= format_percent(@cn_10y&.yield_pct) %></span>
                <span class="text-gray-400">(<%= @cn_10y&.date %>)</span>
            </span>
        </div>

        <% base_params = { sort: @sort_param } %>
        <% base_params[:only_div5y] = '1' if @only_div5y %>
        <% base_params[:roe_5y_avg_ge_12] = '1' if @roe_5y_avg_ge_12 %>
        <% base_params[:roe_5y_min_ge_8] = '1' if @roe_5y_min_ge_8 %>
        <% base_params[:include_category_ids] = @include_category_ids unless @include_category_ids.empty? %>
        <% base_params[:exclude_category_ids] = @exclude_category_ids unless @exclude_category_ids.empty? %>
        <% base_params[:include_pb_levels] = @include_pb_levels unless @include_pb_levels.empty? %>
        <% base_params[:exclude_pb_levels] = @exclude_pb_levels unless @exclude_pb_levels.empty? %>
        <% base_params[:include_pb_percentile_levels] = @include_pb_percentile_levels unless @include_pb_percentile_levels.empty? %>
        <% base_params[:exclude_pb_percentile_levels] = @exclude_pb_percentile_levels unless @exclude_pb_percentile_levels.empty? %>
        <% base_params[:include_pe_levels] = @include_pe_levels unless @include_pe_levels.empty? %>
        <% base_params[:exclude_pe_levels] = @exclude_pe_levels unless @exclude_pe_levels.empty? %>
        <% base_params[:include_pe_percentile_levels] = @include_pe_percentile_levels unless @include_pe_percentile_levels.empty? %>
        <% base_params[:exclude_pe_percentile_levels] = @exclude_pe_percentile_levels unless @exclude_pe_percentile_levels.empty? %>
        <% base_params[:include_roe_levels] = @include_roe_levels unless @include_roe_levels.empty? %>
        <% base_params[:exclude_roe_levels] = @exclude_roe_levels unless @exclude_roe_levels.empty? %>

        <form id="filterForm" method="get" action="/" class="mt-4">
            <input type="hidden" id="sortInput" name="sort" value="<%= @sort_param %>">

            <div class="mt-4 text-sm text-gray-600 font-medium">过滤</div>
            <div class="mt-2 flex flex-wrap items-center gap-3 text-sm">
                <label class="flex items-center gap-2 px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer">
                    <input type="checkbox" name="only_div5y" value="1" <%= @only_div5y ? 'checked' : '' %>>
                    <span>仅显示连续5年分红</span>
                </label>

                <label class="flex items-center gap-2 px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer">
                    <input type="checkbox" name="roe_5y_avg_ge_12" value="1" <%= @roe_5y_avg_ge_12 ? 'checked' : '' %>>
                    <span>ROE近5年均值≥12%</span>
                </label>

                <label class="flex items-center gap-2 px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer">
                    <input type="checkbox" name="roe_5y_min_ge_8" value="1" <%= @roe_5y_min_ge_8 ? 'checked' : '' %>>
                    <span>ROE近5年最低≥8%</span>
                </label>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">包含ROE等级 (<%= @include_roe_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..3).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="include_roe_levels[]" value="<%= lvl %>" <%= @include_roe_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= roe_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">排除ROE等级 (<%= @exclude_roe_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..3).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="exclude_roe_levels[]" value="<%= lvl %>" <%= @exclude_roe_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= roe_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">包含分类 (<%= @include_category_ids.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% @categories.each do |cat| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="include_category_ids[]" value="<%= cat.id %>" <%= @include_category_ids.include?(cat.id) ? 'checked' : '' %>>
                                <span><%= cat.name %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">排除分类 (<%= @exclude_category_ids.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% @categories.each do |cat| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="exclude_category_ids[]" value="<%= cat.id %>" <%= @exclude_category_ids.include?(cat.id) ? 'checked' : '' %>>
                                <span><%= cat.name %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">包含PB等级 (<%= @include_pb_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..6).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="include_pb_levels[]" value="<%= lvl %>" <%= @include_pb_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= pb_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">排除PB等级 (<%= @exclude_pb_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..6).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="exclude_pb_levels[]" value="<%= lvl %>" <%= @exclude_pb_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= pb_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">包含PB分位 (<%= @include_pb_percentile_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..4).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="include_pb_percentile_levels[]" value="<%= lvl %>" <%= @include_pb_percentile_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= pb_percentile_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">排除PB分位 (<%= @exclude_pb_percentile_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..4).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="exclude_pb_percentile_levels[]" value="<%= lvl %>" <%= @exclude_pb_percentile_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= pb_percentile_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">包含PE等级 (<%= @include_pe_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..7).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="include_pe_levels[]" value="<%= lvl %>" <%= @include_pe_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= pe_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">排除PE等级 (<%= @exclude_pe_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..7).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="exclude_pe_levels[]" value="<%= lvl %>" <%= @exclude_pe_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= pe_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">包含PE分位 (<%= @include_pe_percentile_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..3).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="include_pe_percentile_levels[]" value="<%= lvl %>" <%= @include_pe_percentile_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= pe_percentile_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

                <details class="relative">
                    <summary class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200 cursor-pointer select-none">排除PE分位 (<%= @exclude_pe_percentile_levels.size %>)</summary>
                    <div class="absolute z-10 mt-2 w-64 max-h-72 overflow-auto bg-white border border-gray-200 rounded shadow p-2">
                        <% (1..3).each do |lvl| %>
                            <label class="flex items-center gap-2 px-2 py-1 hover:bg-gray-50 rounded">
                                <input type="checkbox" name="exclude_pe_percentile_levels[]" value="<%= lvl %>" <%= @exclude_pe_percentile_levels.include?(lvl) ? 'checked' : '' %>>
                                <span><%= pe_percentile_level_label(lvl) %></span>
                            </label>
                        <% end %>
                    </div>
                </details>

            </div>

            <div class="mt-4 text-sm text-gray-600 font-medium">排序</div>
            <div id="sortPalette" class="mt-2 flex flex-wrap items-center gap-2 text-sm">
                <% current_sort_by_field = @sorts.to_h { |s| [s[:field], s[:order]] } %>
                <% @allowed_sort_fields.each do |f| %>
                    <% active_order = current_sort_by_field[f] %>
                    <span class="sort-palette-item inline-flex items-center px-2 py-1 rounded-full border <%= active_order ? 'bg-blue-50 text-blue-700 border-blue-200' : 'bg-white text-gray-700 border-gray-200' %>" data-field="<%= f %>" data-label="<%= sort_label(f) %>">
                        <span class="<%= active_order ? 'font-semibold' : '' %>"><%= sort_label(f) %></span>
                        <div class="flex items-center ml-2 gap-1">
                            <button type="button" class="sort-add px-2 py-0.5 rounded <%= active_order == 'asc' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>" data-field="<%= f %>" data-order="asc" data-label="<%= sort_label(f) %>">↑</button>
                            <button type="button" class="sort-add px-2 py-0.5 rounded <%= active_order == 'desc' ? 'bg-blue-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>" data-field="<%= f %>" data-order="desc" data-label="<%= sort_label(f) %>">↓</button>
                        </div>
                    </span>
                <% end %>
            </div>

            <div class="mt-4 flex flex-wrap items-center gap-3">
                <a href="/?<%= build_query({ sort: @sort_param }) %>" class="text-blue-600 hover:underline text-sm">清空过滤</a>
                <a href="/" class="text-blue-600 hover:underline text-sm">清空全部</a>
            </div>
        </form>

    </div>

    <div class="mt-4 flex flex-wrap items-center gap-2 text-sm">
        <div id="activeSorts" class="flex flex-wrap items-center gap-2" data-empty-label="未设置排序">
            <% @sorts.each_with_index do |s, idx| %>
                <span class="active-sort inline-flex items-center px-2 py-1 bg-blue-50 text-blue-700 rounded-full border border-blue-100 cursor-move select-none" draggable="true" data-field="<%= s[:field] %>" data-order="<%= s[:order] %>">
                    <span class="sort-index text-blue-400 mr-1"><%= (idx + 1).to_s %>.</span>
                    <span class="font-semibold"><%= sort_label(s[:field]) %></span>
                    <button type="button" class="sort-toggle ml-2 text-blue-600 hover:text-blue-900"><%= s[:order] == 'desc' ? '↓' : '↑' %></button>
                    <button type="button" class="sort-remove ml-2 text-blue-600 hover:text-blue-900">×</button>
                </span>
            <% end %>
        </div>
        <% if @sorts.any? %>
            <a href="/?clear_sorts=1" class="ml-2 text-blue-600 hover:underline">清空排序</a>
        <% end %>
    </div>

    <div class="mt-2 flex flex-wrap items-center gap-2 text-sm">
        <% @included_categories.each do |cat| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">包含</span>
                <span class="ml-1"><%= cat.name %></span>
                <a href="/?<%= build_query(base_params.merge(remove_include_category_id: cat.id)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @excluded_categories.each do |cat| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">排除</span>
                <span class="ml-1"><%= cat.name %></span>
                <a href="/?<%= build_query(base_params.merge(remove_exclude_category_id: cat.id)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @include_pb_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">包含PB</span>
                <span class="ml-1"><%= pb_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_include_pb_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @exclude_pb_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">排除PB</span>
                <span class="ml-1"><%= pb_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_exclude_pb_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @include_pb_percentile_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">包含PB分位</span>
                <span class="ml-1"><%= pb_percentile_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_include_pb_percentile_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @exclude_pb_percentile_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">排除PB分位</span>
                <span class="ml-1"><%= pb_percentile_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_exclude_pb_percentile_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @include_pe_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">包含PE</span>
                <span class="ml-1"><%= pe_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_include_pe_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @exclude_pe_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">排除PE</span>
                <span class="ml-1"><%= pe_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_exclude_pe_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @include_pe_percentile_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">包含PE分位</span>
                <span class="ml-1"><%= pe_percentile_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_include_pe_percentile_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @exclude_pe_percentile_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">排除PE分位</span>
                <span class="ml-1"><%= pe_percentile_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_exclude_pe_percentile_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @include_roe_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">包含ROE</span>
                <span class="ml-1"><%= roe_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_include_roe_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% @exclude_roe_levels.each do |lvl| %>
            <span class="inline-flex items-center px-2 py-1 bg-gray-50 text-gray-700 rounded-full border border-gray-200">
                <span class="font-semibold">排除ROE</span>
                <span class="ml-1"><%= roe_level_label(lvl) %></span>
                <a href="/?<%= build_query(base_params.merge(remove_exclude_roe_level: lvl)) %>" class="ml-2 text-gray-500 hover:text-gray-800">×</a>
            </span>
        <% end %>
        <% if @only_div5y %>
            <span class="inline-flex items-center px-2 py-1 bg-green-50 text-green-700 rounded-full border border-green-100">
                <span class="font-semibold">连续5年分红</span>
                <a href="/?<%= build_query(base_params.merge(only_div5y: nil)) %>" class="ml-2 text-green-600 hover:text-green-900">×</a>
            </span>
        <% end %>
        <% if @roe_5y_avg_ge_12 %>
            <span class="inline-flex items-center px-2 py-1 bg-green-50 text-green-700 rounded-full border border-green-100">
                <span class="font-semibold">ROE近5年均值≥12%</span>
                <a href="/?<%= build_query(base_params.merge(roe_5y_avg_ge_12: nil)) %>" class="ml-2 text-green-600 hover:text-green-900">×</a>
            </span>
        <% end %>
        <% if @roe_5y_min_ge_8 %>
            <span class="inline-flex items-center px-2 py-1 bg-green-50 text-green-700 rounded-full border border-green-100">
                <span class="font-semibold">ROE近5年最低≥8%</span>
                <a href="/?<%= build_query(base_params.merge(roe_5y_min_ge_8: nil)) %>" class="ml-2 text-green-600 hover:text-green-900">×</a>
            </span>
        <% end %>
    </div>

    <div class="table-container">
        <table class="w-full text-left border-collapse text-xs">
            <thead>
                <tr class="bg-gray-50 text-gray-700 text-xs uppercase tracking-wider">
                    <th class="p-3 border-b border-gray-200 sticky left-0 bg-gray-50">股票名称</th>
                    <th class="p-3 border-b border-gray-200">分类</th>
                    <th class="p-3 border-b border-gray-200 text-right"><%= sort_link('current_price', '最新价') %></th>
                    <th class="p-3 border-b border-gray-200 text-right font-bold"><%= sort_link('expected_dividend_yield', '预期股息率') %></th>
                    <th class="p-3 border-b border-gray-200 text-right"><%= sort_link('dividend_yield', '历史股息率') %></th>
                    <th class="p-3 border-b border-gray-200 text-right"><%= sort_link('pe_ttm', 'PE(TTM)') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('pe_level', 'PE等级') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('pe_percentile', 'PE分位') %></th>
                    <th class="p-3 border-b border-gray-200 text-right"><%= sort_link('pb', 'PB') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('pb_level', 'PB等级') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('pb_percentile', 'PB分位') %></th>
                    <th class="p-3 border-b border-gray-200 text-right"><%= sort_link('roe_jq', 'ROE') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('roe_level', 'ROE等级') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('pos_30d', '30d分位') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('pos_1y', '1y分位') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('pos_3y', '3y分位') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('pos_5y', '5y分位') %></th>
                    <th class="p-3 border-b border-gray-200 text-center"><%= sort_link('price_position', '全量分位') %></th>
                </tr>
            </thead>
            <tbody class="text-gray-600">
                <% @stocks.each do |stock| %>
                    <tr class="hover:bg-blue-50 transition-colors duration-150 border-b border-gray-100 group">
                        <td class="p-3 font-medium text-gray-800 sticky left-0 bg-white group-hover:bg-blue-50">
                            <a href="/stocks/<%= stock.id %>" class="text-blue-600 hover:text-blue-800 hover:underline">
                                <%= stock.name %>
                            </a>
                            <div class="text-xs text-gray-400 font-mono"><%= stock.code %></div>
                        </td>
                        <td class="p-3">
                            <div class="flex flex-wrap gap-1">
                                <% stock.categories.each do |cat| %>
                                    <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded-full"><%= cat.name %></span>
                                <% end %>
                            </div>
                        </td>
                        <td class="p-3 text-right"><%= format_decimal(stock.current_price, 2) %></td>
                        <td class="p-3 text-right font-bold text-blue-700"><%= format_percent(stock.expected_dividend_yield) %></td>
                        <td class="p-3 text-right"><%= stock.dividend_yield.nil? ? '未同步' : format_percent(stock.dividend_yield) %></td>
                        <td class="p-3 text-right"><%= format_decimal(stock.pe_ttm, 2) %></td>
                        <td class="p-3 text-center">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= pe_level_badge_class(stock.pe_level) %> font-semibold"><%= pe_level_label(stock.pe_level) %></span>
                        </td>
                        <td class="p-3 text-center">
                            <% if stock.pe_ttm && stock.pe_ttm.to_f < 0 %>
                                <div>亏损</div>
                                <div class="text-xs text-gray-400">-</div>
                            <% elsif stock.pe_ttm && stock.pe_ttm.to_f > 0 && stock.pe_percentile.nil? %>
                                <div>未同步</div>
                                <div class="text-xs text-gray-400">-</div>
                            <% else %>
                                <div><%= pe_percentile_level_label(stock.pe_percentile_level) %></div>
                                <div class="text-xs text-gray-400"><%= format_ratio_percent(stock.pe_percentile) %></div>
                            <% end %>
                        </td>
                        <td class="p-3 text-right"><%= format_decimal(stock.pb, 2) %></td>
                        <td class="p-3 text-center">
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= pb_level_badge_class(stock.pb_level) %> font-semibold"><%= pb_level_label(stock.pb_level) %></span>
                        </td>
                        <td class="p-3 text-center">
                            <% if stock.pb && stock.pb.to_f > 0 && stock.pb_percentile.nil? %>
                                <div>未同步</div>
                                <div class="text-xs text-gray-400">-</div>
                            <% else %>
                                <div><%= pb_percentile_level_label(stock.pb_percentile_level) %></div>
                                <div class="text-xs text-gray-400"><%= format_ratio_percent(stock.pb_percentile) %></div>
                            <% end %>
                        </td>
                        <td class="p-3 text-right"><%= stock.roe_jq.nil? ? '未同步' : format_percent(stock.roe_jq) %></td>
                        <td class="p-3 text-center">
                            <% if stock.roe_level.nil? %>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full border bg-gray-50 text-gray-500 border-gray-200 font-semibold">未同步</span>
                            <% else %>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= roe_level_badge_class(stock.roe_level) %> font-semibold"><%= roe_level_label(stock.roe_level) %></span>
                            <% end %>
                        </td>
                        
                        <td class="p-3 text-center <%= position_color(stock.pos_30d) %>">
                            <%= format_ratio_percent(stock.pos_30d) %>
                        </td>
                        <td class="p-3 text-center <%= position_color(stock.pos_1y) %>">
                            <%= format_ratio_percent(stock.pos_1y) %>
                        </td>
                        <td class="p-3 text-center <%= position_color(stock.pos_3y) %>">
                            <%= format_ratio_percent(stock.pos_3y) %>
                        </td>
                        <td class="p-3 text-center <%= position_color(stock.pos_5y) %>">
                            <%= format_ratio_percent(stock.pos_5y) %>
                        </td>
                        <td class="p-3 text-center font-bold">
                            <%= format_ratio_percent(stock.price_position) %>
                        </td>
                    </tr>
                <% end %>
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4 flex items-center justify-between text-sm">
    <div class="text-gray-600">第 <%= @page %> / <%= @total_pages %> 页</div>
    <div class="flex items-center gap-2">
        <% prev_page = @page > 1 ? (@page - 1) : nil %>
        <% next_page = @page < @total_pages ? (@page + 1) : nil %>
        <% page_params = base_params.dup %>
        <% page_params.delete(:clear_sorts) %>
        <% page_params.delete(:remove_sort) %>
        <% page_params.delete(:remove_include_category_id) %>
        <% page_params.delete(:remove_exclude_category_id) %>
        <% page_params.delete(:remove_include_pb_level) %>
        <% page_params.delete(:remove_exclude_pb_level) %>
        <% page_params.delete(:remove_include_pb_percentile_level) %>
        <% page_params.delete(:remove_exclude_pb_percentile_level) %>
        <% page_params.delete(:remove_include_pe_level) %>
        <% page_params.delete(:remove_exclude_pe_level) %>
        <% page_params.delete(:remove_include_pe_percentile_level) %>
        <% page_params.delete(:remove_exclude_pe_percentile_level) %>

        <% if prev_page %>
            <a class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200" href="/?<%= build_query(page_params.merge(page: prev_page)) %>">上一页</a>
        <% else %>
            <span class="px-3 py-1 rounded bg-gray-50 text-gray-400">上一页</span>
        <% end %>
        <% if next_page %>
            <a class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200" href="/?<%= build_query(page_params.merge(page: next_page)) %>">下一页</a>
        <% else %>
            <span class="px-3 py-1 rounded bg-gray-50 text-gray-400">下一页</span>
        <% end %>
    </div>
</div>

<script>
    (function() {
        const activeSorts = document.getElementById('activeSorts');
        const palette = document.getElementById('sortPalette');
        const sortInput = document.getElementById('sortInput');
        const filterForm = document.getElementById('filterForm');
        if (!activeSorts || !palette || !sortInput || !filterForm) return;

        function getSortsFromDom() {
            return Array.from(activeSorts.querySelectorAll('.active-sort')).map((el) => ({
                field: el.dataset.field,
                order: el.dataset.order
            }));
        }

        function serializeSorts(sorts) {
            return (sorts || []).map((s) => `${s.field}:${s.order}`).join(',');
        }

        function setSortInputFromDom() {
            sortInput.value = serializeSorts(getSortsFromDom());
        }

        function submitForm() {
            if (typeof filterForm.requestSubmit === 'function') {
                filterForm.requestSubmit();
            } else {
                filterForm.submit();
            }
        }

        function refreshSortIndices() {
            Array.from(activeSorts.querySelectorAll('.active-sort')).forEach((el, idx) => {
                const indexEl = el.querySelector('.sort-index');
                if (indexEl) indexEl.textContent = `${idx + 1}.`;
            });
        }

        function refreshPaletteState() {
            const byField = new Map(getSortsFromDom().map((s) => [s.field, s.order]));
            Array.from(palette.querySelectorAll('.sort-palette-item')).forEach((item) => {
                const field = item.dataset.field;
                const order = byField.get(field);

                if (order) {
                    item.classList.add('bg-blue-50', 'text-blue-700', 'border-blue-200');
                    item.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
                    const nameEl = item.querySelector('span');
                    if (nameEl) nameEl.classList.add('font-semibold');
                } else {
                    item.classList.remove('bg-blue-50', 'text-blue-700', 'border-blue-200');
                    item.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
                    const nameEl = item.querySelector('span');
                    if (nameEl) nameEl.classList.remove('font-semibold');
                }

                const ascBtn = item.querySelector('.sort-add[data-order="asc"]');
                const descBtn = item.querySelector('.sort-add[data-order="desc"]');
                [ascBtn, descBtn].forEach((btn) => {
                    if (!btn) return;
                    btn.classList.remove('bg-blue-600', 'text-white');
                    btn.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                });
                if (order === 'asc' && ascBtn) {
                    ascBtn.classList.add('bg-blue-600', 'text-white');
                    ascBtn.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                }
                if (order === 'desc' && descBtn) {
                    descBtn.classList.add('bg-blue-600', 'text-white');
                    descBtn.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                }
            });
        }

        function syncSortUi() {
            refreshSortIndices();
            setSortInputFromDom();
            refreshPaletteState();
        }

        function buildActiveSortChip(field, label, order) {
            const span = document.createElement('span');
            span.className = 'active-sort inline-flex items-center px-2 py-1 bg-blue-50 text-blue-700 rounded-full border border-blue-100 cursor-move select-none';
            span.draggable = true;
            span.dataset.field = field;
            span.dataset.order = order;
            span.innerHTML = `
                <span class="sort-index text-blue-400 mr-1"></span>
                <span class="font-semibold"></span>
                <button type="button" class="sort-toggle ml-2 text-blue-600 hover:text-blue-900"></button>
                <button type="button" class="sort-remove ml-2 text-blue-600 hover:text-blue-900">×</button>
            `;
            span.querySelector('.font-semibold').textContent = label || field;
            span.querySelector('.sort-toggle').textContent = order === 'desc' ? '↓' : '↑';
            return span;
        }

        palette.addEventListener('click', (e) => {
            const btn = e.target.closest('.sort-add');
            if (!btn) return;
            const field = btn.dataset.field;
            const order = btn.dataset.order;
            const label = btn.dataset.label || field;
            if (!field || !order) return;

            const existing = activeSorts.querySelector(`.active-sort[data-field="${CSS.escape(field)}"]`);
            if (existing) {
                existing.dataset.order = order;
                const toggle = existing.querySelector('.sort-toggle');
                if (toggle) toggle.textContent = order === 'desc' ? '↓' : '↑';
            } else {
                activeSorts.appendChild(buildActiveSortChip(field, label, order));
            }
            syncSortUi();
            submitForm();
        });

        activeSorts.addEventListener('click', (e) => {
            const removeBtn = e.target.closest('.sort-remove');
            if (removeBtn) {
                const chip = removeBtn.closest('.active-sort');
                if (chip) chip.remove();
                syncSortUi();
                submitForm();
                return;
            }

            const toggleBtn = e.target.closest('.sort-toggle');
            if (toggleBtn) {
                const chip = toggleBtn.closest('.active-sort');
                if (!chip) return;
                chip.dataset.order = chip.dataset.order === 'desc' ? 'asc' : 'desc';
                toggleBtn.textContent = chip.dataset.order === 'desc' ? '↓' : '↑';
                syncSortUi();
                submitForm();
            }
        });

        let dragging = null;

        activeSorts.addEventListener('dragstart', (e) => {
            const el = e.target.closest('.active-sort');
            if (!el) return;
            dragging = el;
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', el.dataset.field || '');
        });

        activeSorts.addEventListener('dragover', (e) => {
            if (!dragging) return;
            e.preventDefault();
            const target = e.target.closest('.active-sort');
            if (!target || target === dragging) return;
            const rect = target.getBoundingClientRect();
            const before = e.clientX < rect.left + rect.width / 2;
            if (before) {
                activeSorts.insertBefore(dragging, target);
            } else {
                activeSorts.insertBefore(dragging, target.nextSibling);
            }
        });

        activeSorts.addEventListener('dragend', () => {
            if (!dragging) return;
            dragging = null;
            syncSortUi();
            submitForm();
        });

        filterForm.addEventListener('change', (e) => {
            const t = e.target;
            if (t && t.id === 'sortInput') return;
            submitForm();
        });

        syncSortUi();
    })();
</script>

<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-blue-50 p-6 rounded-lg border border-blue-100">
        <h3 class="text-lg font-semibold text-blue-800 mb-2">💡 什么是位置指标？</h3>
        <p class="text-blue-700 text-sm leading-relaxed">
            位置指标表示当前收盘价在对应滚动窗口内的百分比。数值越小（越接近 0），说明当前价格越接近该周期的历史低位；数值越大（越接近 1），说明当前价格越接近该周期的历史高位。
        </p>
    </div>
    <div class="bg-green-50 p-6 rounded-lg border border-green-100">
        <h3 class="text-lg font-semibold text-green-800 mb-2">📈 什么是预期股息率？</h3>
        <p class="text-green-700 text-sm leading-relaxed">
            预期股息率是基于最近 12 个月内公布的现金分红总额除以当前股价计算得出。它是评估高股息投资价值的核心参考。
        </p>
    </div>
</div>
