                                <% end %>
                            </div>
                        </td>
                        <td class="p-3 text-right hidden md:table-cell"><%= format_decimal(stock.current_price, 2) %></td>
                        <td class="p-3 text-right font-bold text-blue-700"><%= stock.dividend_yield.nil? ? '未同步' : format_percent(stock.dividend_yield) %></td>
                        <td class="p-3 text-right hidden md:table-cell"><%= stock.dividend_payout_ratio.nil? ? '-' : format_percent(stock.dividend_payout_ratio) %></td>
                        <td class="p-3 text-right"><%= format_decimal(stock.pe_ttm, 2) %></td>
                        <td class="p-3 text-right hidden md:table-cell"><%= stock.peg.nil? ? '-' : format_decimal(stock.peg, 2) %></td>
                        <td class="p-3 text-center hidden md:table-cell">
                            <% if stock.peg_level.nil? %>
                                <span class="text-gray-400">-</span>
                            <% else %>
                                <a href="/kb/peg" class="inline-flex items-center px-2 py-0.5 rounded-full border <%= peg_level_badge_class(stock.peg_level) %> font-semibold hover:opacity-90" title="查看知识库：PEG"><%= peg_level_label(stock.peg_level) %></a>
                            <% end %>
                        </td>
                        <td class="p-3 text-right hidden md:table-cell"><%= stock.asset_liability_ratio.nil? ? '未同步' : format_percent(stock.asset_liability_ratio) %></td>
                        <td class="p-3 text-right hidden md:table-cell"><%= stock.fcf_yield.nil? ? '未同步' : format_percent(stock.fcf_yield) %></td>
                        <td class="p-3 text-right hidden md:table-cell"><%= stock.fcf_ev.nil? ? '未同步' : format_percent(stock.fcf_ev) %></td>
                        <td class="p-3 text-center">
                            <a href="/kb/pe" class="inline-flex items-center px-2 py-0.5 rounded-full border <%= pe_level_badge_class(stock.pe_level) %> font-semibold hover:opacity-90" title="查看知识库：PE"><%= pe_level_label(stock.pe_level) %></a>
                        </td>
                        <td class="p-3 text-center">
                            <% if stock.pe_ttm && stock.pe_ttm.to_f < 0 %>
                                <div>亏损</div>
                                <div class="text-xs text-gray-400">-</div>
                            <% elsif stock.pe_ttm && stock.pe_ttm.to_f > 0 && stock.pe_percentile.nil? %>
                                <% if (@pe_hist_counts[stock.id] || 0) == 0 %>
                                    <div>无数据</div>
                                <% else %>
                                    <div>未同步</div>
                                <% end %>
                                <div class="text-xs text-gray-400">-</div>
                            <% else %>
                                <div><%= pe_percentile_level_label(stock.pe_percentile_level) %></div>
                                <div class="text-xs text-gray-400"><%= format_ratio_percent(stock.pe_percentile) %></div>
                            <% end %>
                        </td>
                        <td class="p-3 text-right"><%= format_decimal(stock.pb, 2) %></td>
                        <td class="p-3 text-center">
                            <a href="/kb/pb" class="inline-flex items-center px-2 py-0.5 rounded-full border <%= pb_level_badge_class(stock.pb_level) %> font-semibold hover:opacity-90" title="查看知识库：PB"><%= pb_level_label(stock.pb_level) %></a>
                        </td>
                        <td class="p-3 text-center">
                            <% if stock.pb && stock.pb.to_f > 0 && stock.pb_percentile.nil? %>
                                <% if (@pb_hist_counts[stock.id] || 0) == 0 %>
                                    <div>无数据</div>
                                <% else %>
                                    <div>未同步</div>
                                <% end %>
                                <div class="text-xs text-gray-400">-</div>
                            <% else %>
                                <div><%= pb_percentile_level_label(stock.pb_percentile_level) %></div>
                                <div class="text-xs text-gray-400"><%= format_ratio_percent(stock.pb_percentile) %></div>
                            <% end %>
                        </td>
                        <td class="p-3 text-right"><%= stock.roe_jq.nil? ? '未同步' : format_percent(stock.roe_jq) %></td>
                        <td class="p-3 text-right hidden md:table-cell"><%= stock.roe_trend_score.nil? ? '-' : format_decimal(stock.roe_trend_score, 1) %></td>
                        <td class="p-3 text-center">
                            <% if stock.roe_level.nil? %>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full border bg-gray-50 text-gray-500 border-gray-200 font-semibold">未同步</span>
                            <% else %>
                                <a href="/kb/roe" class="inline-flex items-center px-2 py-0.5 rounded-full border <%= roe_level_badge_class(stock.roe_level) %> font-semibold hover:opacity-90" title="查看知识库：ROE"><%= roe_level_label(stock.roe_level) %></a>
                            <% end %>
                        </td>
                        
                        <td class="p-3 text-center <%= position_color(stock.pos_30d) %> hidden md:table-cell">
                            <%= format_ratio_percent(stock.pos_30d) %>
                        </td>
                        <td class="p-3 text-right hidden md:table-cell">
                            <% if stock.drop_30d.nil? %>
                                <span class="text-gray-400">-</span>
                            <% else %>
                                <span class="<%= stock.drop_30d.to_f > 0 ? 'text-red-600 font-semibold' : (stock.drop_30d.to_f < 0 ? 'text-green-600 font-semibold' : 'text-gray-500') %>"><%= format_percent(stock.drop_30d) %></span>
                            <% end %>
                        </td>
                        <td class="p-3 text-center <%= position_color(stock.pos_1y) %> hidden md:table-cell">
                            <%= format_ratio_percent(stock.pos_1y) %>
                        </td>
                        <td class="p-3 text-center <%= position_color(stock.pos_3y) %> hidden md:table-cell">
                            <%= format_ratio_percent(stock.pos_3y) %>
                        </td>
                        <td class="p-3 text-center <%= position_color(stock.pos_5y) %> hidden md:table-cell">
                            <%= format_ratio_percent(stock.pos_5y) %>
                        </td>
                        <td class="p-3 text-center font-bold">
                            <%= format_ratio_percent(stock.price_position) %>
                        </td>
                    </tr>
                <% end %>
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4 flex items-center justify-between text-sm">
    <div class="text-gray-600">第 <%= @page %> / <%= @total_pages %> 页</div>
    <div class="flex items-center gap-2">
        <% prev_page = @page > 1 ? (@page - 1) : nil %>
        <% next_page = @page < @total_pages ? (@page + 1) : nil %>
        <% page_params = base_params.dup %>
        <% page_params.delete(:clear_sorts) %>
        <% page_params.delete(:remove_sort) %>
        <% page_params.delete(:remove_include_category_id) %>
        <% page_params.delete(:remove_exclude_category_id) %>
        <% page_params.delete(:remove_include_pb_level) %>
        <% page_params.delete(:remove_exclude_pb_level) %>
        <% page_params.delete(:remove_include_pb_percentile_level) %>
        <% page_params.delete(:remove_exclude_pb_percentile_level) %>
        <% page_params.delete(:remove_include_pe_level) %>
        <% page_params.delete(:remove_exclude_pe_level) %>
        <% page_params.delete(:remove_include_pe_percentile_level) %>
        <% page_params.delete(:remove_exclude_pe_percentile_level) %>

        <% if prev_page %>
            <a class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200" href="<%= base_path %>?<%= build_query(page_params.merge(page: prev_page)) %>">上一页</a>
        <% else %>
            <span class="px-3 py-1 rounded bg-gray-50 text-gray-400">上一页</span>
        <% end %>
        <% if next_page %>
            <a class="px-3 py-1 rounded bg-gray-100 text-gray-700 hover:bg-gray-200" href="<%= base_path %>?<%= build_query(page_params.merge(page: next_page)) %>">下一页</a>
        <% else %>
            <span class="px-3 py-1 rounded bg-gray-50 text-gray-400">下一页</span>
        <% end %>
    </div>
</div>

<% if @layer_index_series && @layer_index_series.any? %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<% end %>
<script>
    <% if @layer_index_series && @layer_index_series.any? %>
        (function() {
            const el = document.getElementById('layerIndexChart');
            if (!el || !window.Chart) return;
            const labels = <%= @layer_index_series.map { |x| x[:date].strftime('%Y-%m-%d') }.to_json %>;
            const values = <%= @layer_index_series.map { |x| x[:value].to_f.round(4) }.to_json %>;
            const ctx = el.getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        label: '收息底仓指数',
                        data: values,
                        borderColor: 'rgba(37, 99, 235, 1)',
                        backgroundColor: 'rgba(37, 99, 235, 0.12)',
                        borderWidth: 2,
                        pointRadius: 0,
                        tension: 0.18,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { mode: 'index', intersect: false }
                    },
                    interaction: { mode: 'index', intersect: false },
                    scales: {
                        x: { ticks: { maxRotation: 0, autoSkip: true, maxTicksLimit: 8 } },
                        y: { ticks: { callback: (v) => Number(v).toFixed(0) } }
                    }
                }
            });
        })();
    <% end %>

    (function() {
        const activeSorts = document.getElementById('activeSorts');
        const palette = document.getElementById('sortPalette');
        const sortInput = document.getElementById('sortInput');
        const filterForm = document.getElementById('filterForm');
        if (!activeSorts || !palette || !sortInput || !filterForm) return;

        function getSortsFromDom() {
            return Array.from(activeSorts.querySelectorAll('.active-sort')).map((el) => ({
                field: el.dataset.field,
                order: el.dataset.order
            }));
        }

        function serializeSorts(sorts) {
            return (sorts || []).map((s) => `${s.field}:${s.order}`).join(',');
        }

        function setSortInputFromDom() {
            sortInput.value = serializeSorts(getSortsFromDom());
        }

        function submitForm() {
            if (typeof filterForm.requestSubmit === 'function') {
                filterForm.requestSubmit();
            } else {
                filterForm.submit();
            }
        }

        function refreshSortIndices() {
            Array.from(activeSorts.querySelectorAll('.active-sort')).forEach((el, idx) => {
                const indexEl = el.querySelector('.sort-index');
                if (indexEl) indexEl.textContent = `${idx + 1}.`;
            });
        }

        function refreshPaletteState() {
            const byField = new Map(getSortsFromDom().map((s) => [s.field, s.order]));
            Array.from(palette.querySelectorAll('.sort-palette-item')).forEach((item) => {
                const field = item.dataset.field;
                const order = byField.get(field);

                if (order) {
                    item.classList.add('bg-blue-50', 'text-blue-700', 'border-blue-200');
                    item.classList.remove('bg-white', 'text-gray-700', 'border-gray-200');
                    const nameEl = item.querySelector('span');
                    if (nameEl) nameEl.classList.add('font-semibold');
                } else {
                    item.classList.remove('bg-blue-50', 'text-blue-700', 'border-blue-200');
                    item.classList.add('bg-white', 'text-gray-700', 'border-gray-200');
                    const nameEl = item.querySelector('span');
                    if (nameEl) nameEl.classList.remove('font-semibold');
                }

                const ascBtn = item.querySelector('.sort-add[data-order="asc"]');
                const descBtn = item.querySelector('.sort-add[data-order="desc"]');
                [ascBtn, descBtn].forEach((btn) => {
                    if (!btn) return;
                    btn.classList.remove('bg-blue-600', 'text-white');
                    btn.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                });
                if (order === 'asc' && ascBtn) {
                    ascBtn.classList.add('bg-blue-600', 'text-white');
                    ascBtn.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                }
                if (order === 'desc' && descBtn) {
                    descBtn.classList.add('bg-blue-600', 'text-white');
                    descBtn.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                }
            });
        }

        function syncSortUi() {
            refreshSortIndices();
            setSortInputFromDom();
            refreshPaletteState();
        }

        function buildActiveSortChip(field, label, order) {
            const span = document.createElement('span');
            span.className = 'active-sort inline-flex items-center px-2 py-1 bg-blue-50 text-blue-700 rounded-full border border-blue-100 cursor-move select-none';
            span.draggable = true;
            span.dataset.field = field;
            span.dataset.order = order;
            span.innerHTML = `
                <span class="sort-index text-blue-400 mr-1"></span>
                <span class="font-semibold"></span>
                <button type="button" class="sort-toggle ml-2 text-blue-600 hover:text-blue-900"></button>
                <button type="button" class="sort-remove ml-2 text-blue-600 hover:text-blue-900">×</button>
            `;
            span.querySelector('.font-semibold').textContent = label || field;
            span.querySelector('.sort-toggle').textContent = order === 'desc' ? '↓' : '↑';
            return span;
        }

        palette.addEventListener('click', (e) => {
            const btn = e.target.closest('.sort-add');
            if (!btn) return;
            const field = btn.dataset.field;
            const order = btn.dataset.order;
            const label = btn.dataset.label || field;
            if (!field || !order) return;

            const existing = activeSorts.querySelector(`.active-sort[data-field="${CSS.escape(field)}"]`);
            if (existing) {
                existing.dataset.order = order;
                const toggle = existing.querySelector('.sort-toggle');
                if (toggle) toggle.textContent = order === 'desc' ? '↓' : '↑';
            } else {
                activeSorts.appendChild(buildActiveSortChip(field, label, order));
            }
            syncSortUi();
            submitForm();
        });

        activeSorts.addEventListener('click', (e) => {
            const removeBtn = e.target.closest('.sort-remove');
            if (removeBtn) {
                const chip = removeBtn.closest('.active-sort');
                if (chip) chip.remove();
                syncSortUi();
                submitForm();
                return;
            }

            const toggleBtn = e.target.closest('.sort-toggle');
            if (toggleBtn) {
                const chip = toggleBtn.closest('.active-sort');
                if (!chip) return;
                chip.dataset.order = chip.dataset.order === 'desc' ? 'asc' : 'desc';
                toggleBtn.textContent = chip.dataset.order === 'desc' ? '↓' : '↑';
                syncSortUi();
                submitForm();
            }
        });

        let dragging = null;

        activeSorts.addEventListener('dragstart', (e) => {
            const el = e.target.closest('.active-sort');
            if (!el) return;
            dragging = el;
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', el.dataset.field || '');
        });

        activeSorts.addEventListener('dragover', (e) => {
            if (!dragging) return;
            e.preventDefault();
            const target = e.target.closest('.active-sort');
            if (!target || target === dragging) return;
            const rect = target.getBoundingClientRect();
            const before = e.clientX < rect.left + rect.width / 2;
            if (before) {
                activeSorts.insertBefore(dragging, target);
            } else {
                activeSorts.insertBefore(dragging, target.nextSibling);
            }
        });

        activeSorts.addEventListener('dragend', () => {
            if (!dragging) return;
            dragging = null;
            syncSortUi();
            submitForm();
        });

        filterForm.addEventListener('change', (e) => {
            const t = e.target;
            if (t && t.id === 'sortInput') return;
            if (t && (t.classList.contains('adv-field') || t.classList.contains('adv-op') || t.classList.contains('adv-value'))) return;
            submitForm();
        });

        syncSortUi();
    })();

    (function() {
        const advRows = document.getElementById('advRows');
        const addBtn = document.getElementById('advAddRow');
        const applyBtn = document.getElementById('advApply');
        if (!advRows || !addBtn || !applyBtn) return;

        function syncRowUi(row) {
            const fieldSel = row.querySelector('.adv-field');
            const opSel = row.querySelector('.adv-op');
            const valueInput = row.querySelector('.adv-value');
            if (!fieldSel || !opSel || !valueInput) return;

            const opt = fieldSel.options[fieldSel.selectedIndex];
            const fieldType = opt ? (opt.getAttribute('data-type') || '') : '';
            const placeholder = opt ? (opt.getAttribute('data-placeholder') || '') : '';

            const prevOp = opSel.value;
            const numericOps = ['>', '>=', '<', '<=', '=', '!=', 'is_null', 'not_null'];
            const textOps = ['contains', 'not_contains', 'starts_with', 'ends_with', '=', '!=', 'is_null', 'not_null'];
            const desiredOps = fieldType === 'text' ? textOps : numericOps;

            const opLabels = { contains: '包含', not_contains: '不包含', starts_with: '开头是', ends_with: '结尾是', is_null: '为空', not_null: '不为空', '=': '等于', '!=': '不等于' };
            opSel.innerHTML = '<option value=\"\">条件</option>' + desiredOps.map((x) => `<option value=\"${x}\">${opLabels[x] || x}</option>`).join('');
            if (desiredOps.includes(prevOp)) {
                opSel.value = prevOp;
            }

            const op = opSel.value;
            if (op === 'is_null' || op === 'not_null') {
                valueInput.value = '';
                valueInput.disabled = true;
                valueInput.placeholder = '';
            } else {
                valueInput.disabled = false;
                valueInput.placeholder = placeholder;
            }
        }

        function createRow() {
            const row = document.createElement('div');
            row.className = 'adv-row flex flex-wrap items-center gap-2';
            row.innerHTML = advRows.querySelector('.adv-row') ? advRows.querySelector('.adv-row').innerHTML : '';
            return row;
        }

        function bindRow(row) {
            const removeBtn = row.querySelector('.adv-remove');
            const fieldSel = row.querySelector('.adv-field');
            const opSel = row.querySelector('.adv-op');
            const valueInput = row.querySelector('.adv-value');
            if (removeBtn) {
                removeBtn.addEventListener('click', () => {
                    if (advRows.querySelectorAll('.adv-row').length <= 1) {
                        row.querySelectorAll('select, input').forEach((el) => {
                            if (el.tagName === 'SELECT') el.value = '';
                            if (el.tagName === 'INPUT') el.value = '';
                        });
                        syncRowUi(row);
                        return;
                    }
                    row.remove();
                });
            }
            if (fieldSel) fieldSel.addEventListener('change', () => syncRowUi(row));
            if (opSel) opSel.addEventListener('change', () => syncRowUi(row));
            if (valueInput) {
                valueInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        applyBtn.click();
                    }
                });
            }
            syncRowUi(row);
        }

        Array.from(advRows.querySelectorAll('.adv-row')).forEach(bindRow);

        addBtn.addEventListener('click', () => {
            const row = createRow();
            if (!row.innerHTML) return;
            row.querySelectorAll('select, input').forEach((el) => {
                if (el.tagName === 'SELECT') el.value = '';
                if (el.tagName === 'INPUT') el.value = '';
            });
            advRows.appendChild(row);
            bindRow(row);
        });

        applyBtn.addEventListener('click', () => {
            const filterForm = document.getElementById('filterForm');
            if (!filterForm) return;
            if (typeof filterForm.requestSubmit === 'function') {
                filterForm.requestSubmit();
            } else {
                filterForm.submit();
            }
        });
    })();

    (function() {
        const btn = document.getElementById('savePoolBtn');
        const nameField = document.getElementById('poolNameField');
        if (!btn || !nameField) return;
        const form = btn.closest('form');
        if (!form) return;

        btn.addEventListener('click', () => {
            const mode = btn.dataset.mode || 'new';
            const defaultName = btn.dataset.defaultName || '';
            const title = mode === 'edit' ? '更新股票池名称：' : '股票池名称：';
            const name = window.prompt(title, defaultName);
            if (!name) return;
            const trimmed = name.trim();
            if (!trimmed) return;
            nameField.value = trimmed;
            if (typeof form.requestSubmit === 'function') {
                form.requestSubmit();
            } else {
                form.submit();
            }
        });
    })();
</script>

<div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-blue-50 p-6 rounded-lg border border-blue-100">
        <h3 class="text-lg font-semibold text-blue-800 mb-2">💡 什么是位置指标？</h3>
        <p class="text-blue-700 text-sm leading-relaxed">
            位置指标表示当前收盘价在对应滚动窗口内的百分比。数值越小（越接近 0），说明当前价格越接近该周期的历史低位；数值越大（越接近 1），说明当前价格越接近该周期的历史高位。
        </p>
    </div>
    <div class="bg-green-50 p-6 rounded-lg border border-green-100">
        <h3 class="text-lg font-semibold text-green-800 mb-2">📈 什么是历史股息率？</h3>
        <p class="text-green-700 text-sm leading-relaxed">
            历史股息率使用最近一个年度的累计每股派现除以当前股价计算得出。它用于理解公司过去的分红水平，但不代表未来必然维持。
        </p>
    </div>
</div>
