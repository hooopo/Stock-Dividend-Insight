<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stock Dividend Insight</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .table-container {
            overflow-x: auto;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">
    <nav class="bg-blue-600 text-white shadow-lg p-4">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold tracking-tight">Stock Dividend Insight</h1>
            <div class="space-x-4">
                <a href="/" class="hover:text-blue-200">股票列表</a>
                <a href="/kb" class="hover:text-blue-200">知识库</a>
                <span class="text-blue-300 text-sm">最后更新: <%= Time.now.strftime('%Y-%m-%d %H:%M') %></span>
            </div>
        </div>
    </nav>

    <main class="container mx-auto p-6">
        <%= yield %>
    </main>

    <footer class="mt-12 p-6 text-center text-gray-500 border-t border-gray-200">
        <p>&copy; 2026 Stock Dividend Insight - 打造稳健的红利投资分析系统</p>
    </footer>
</body>
</html>
