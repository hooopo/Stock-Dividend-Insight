<div class="space-y-6">
    <!-- 头部卡片 -->
    <div class="bg-white rounded-lg shadow-md p-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center">
            <div>
                <div class="flex items-center space-x-3">
                    <h1 class="text-3xl font-bold text-gray-900"><%= @stock.name %></h1>
                    <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded text-sm font-mono"><%= @stock.code %></span>
                    <span class="px-2 py-1 <%= @stock.market_id == 1 ? 'bg-red-50 text-red-600' : 'bg-blue-50 text-blue-600' %> rounded text-xs">
                        <%= @stock.market_id == 1 ? '上证' : '深证' %>
                    </span>
                    <% if cyclical_stock?(@stock) %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= tag_badge_class('cycle') %> text-xs font-semibold" title="行业属性偏周期">周期</span>
                    <% end %>
                    <% if high_volatility_stock?(@stock) %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= tag_badge_class('volatile') %> text-xs font-semibold" title="行业属性波动相对更大">波动大</span>
                    <% end %>
                    
                    <div class="flex flex-wrap gap-1 ml-4">
                        <% @stock.categories.each do |cat| %>
                            <a href="/?include_category_ids[]=<%= cat.id %>" class="px-2 py-0.5 bg-blue-50 text-blue-600 text-xs rounded-full hover:bg-blue-100"><%= cat.name %></a>
                        <% end %>
                    </div>
                    
                    <div class="flex space-x-2 ml-4">
                        <% market_prefix = @stock.market_id == 1 ? 'sh' : 'sz' %>
                        <a href="https://quote.eastmoney.com/<%= market_prefix %><%= @stock.code %>.html" target="_blank" class="text-xs text-blue-500 hover:text-blue-700 flex items-center">
                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                            东方财富
                        </a>
                        <a href="https://finance.sina.com.cn/realstock/company/<%= market_prefix %><%= @stock.code %>/nc.shtml" target="_blank" class="text-xs text-orange-500 hover:text-orange-700 flex items-center">
                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                            新浪财经
                        </a>
                    </div>
                </div>
                <p class="mt-2 text-gray-500">最新价: <span class="text-2xl font-semibold text-blue-600">¥<%= format_decimal(@stock.current_price, 2) %></span></p>
            </div>
            
            <div class="mt-4 md:mt-0 grid grid-cols-2 gap-4 text-sm">
                <div class="p-3 bg-blue-50 rounded-lg">
                    <div class="text-blue-600 mb-1">历史股息率</div>
                    <div class="text-xl font-bold text-blue-800"><%= format_percent(@stock.dividend_yield) %></div>
                </div>
                <div class="p-3 bg-green-50 rounded-lg">
                    <div class="text-green-600 mb-1">全量分位</div>
                    <div class="text-xl font-bold text-green-800"><%= format_ratio_percent(@stock.price_position) %></div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-6">
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">换手率</div>
                <div class="text-base font-semibold text-gray-800"><%= format_percent(@stock.turnover_rate) %></div>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">总市值</div>
                <div class="text-base font-semibold text-gray-800"><%= format_market_cap(@stock.market_cap) %></div>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">成交量</div>
                <div class="text-base font-semibold text-gray-800"><%= format_volume(@stock.volume) %></div>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">均价</div>
                <div class="text-base font-semibold text-gray-800">¥<%= format_decimal(@stock.avg_price, 2) %></div>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">市盈率(TTM)</div>
                <div class="text-base font-semibold text-gray-800"><%= format_decimal(@stock.pe_ttm, 2) %></div>
                <div class="mt-1">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= pe_level_badge_class(@stock.pe_level) %> text-xs font-semibold"><%= pe_level_label(@stock.pe_level) %></span>
                </div>
                <% if @stock.pe_ttm && @stock.pe_ttm.to_f < 0 %>
                    <div class="text-xs text-gray-400 mt-1">亏损</div>
                <% elsif @stock.pe_ttm && @stock.pe_ttm.to_f > 0 && @stock.pe_percentile.nil? %>
                    <div class="text-xs text-gray-400 mt-1">未同步历史估值</div>
                <% else %>
                    <div class="text-xs text-gray-400 mt-1"><%= pe_percentile_level_label(@stock.pe_percentile_level) %> (<%= format_ratio_percent(@stock.pe_percentile) %>)</div>
                <% end %>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">PEG</div>
                <div class="text-base font-semibold text-gray-800"><%= @stock.peg.nil? ? '-' : format_decimal(@stock.peg, 2) %></div>
                <div class="mt-1">
                    <% if @stock.peg_level.nil? %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full border bg-gray-50 text-gray-500 border-gray-200 text-xs font-semibold">-</span>
                    <% else %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= peg_level_badge_class(@stock.peg_level) %> text-xs font-semibold"><%= peg_level_label(@stock.peg_level) %></span>
                    <% end %>
                </div>
                <div class="text-xs text-gray-400 mt-1">净利同比: <%= @stock.net_profit_yoy.nil? ? '-' : format_percent(@stock.net_profit_yoy) %></div>
                <div class="text-xs text-gray-400 mt-1">财报期: <%= @stock.finance_report_date || '-' %></div>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">市净率</div>
                <div class="text-base font-semibold text-gray-800"><%= format_decimal(@stock.pb, 2) %></div>
                <div class="mt-1">
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= pb_level_badge_class(@stock.pb_level) %> text-xs font-semibold"><%= pb_level_label(@stock.pb_level) %></span>
                </div>
                <% if @stock.pb && @stock.pb.to_f > 0 && @stock.pb_percentile.nil? %>
                    <div class="text-xs text-gray-400 mt-1">未同步历史估值</div>
                <% else %>
                    <div class="text-xs text-gray-400 mt-1"><%= pb_percentile_level_label(@stock.pb_percentile_level) %> (<%= format_ratio_percent(@stock.pb_percentile) %>)</div>
                <% end %>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">资产负债率</div>
                <div class="text-base font-semibold text-gray-800"><%= @stock.asset_liability_ratio.nil? ? '未同步' : format_percent(@stock.asset_liability_ratio) %></div>
                <div class="text-xs text-gray-400 mt-1">有息负债率: <%= @stock.interest_debt_ratio.nil? ? '-' : format_percent(@stock.interest_debt_ratio) %></div>
                <div class="text-xs text-gray-400 mt-1">财报期: <%= @stock.finance_report_date || '-' %></div>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">ROE(加权)</div>
                <div class="text-base font-semibold text-gray-800"><%= @stock.roe_jq.nil? ? '未同步' : format_percent(@stock.roe_jq) %></div>
                <div class="mt-1">
                    <% if @stock.roe_level.nil? %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full border bg-gray-50 text-gray-500 border-gray-200 text-xs font-semibold">未同步</span>
                    <% else %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full border <%= roe_level_badge_class(@stock.roe_level) %> text-xs font-semibold"><%= roe_level_label(@stock.roe_level) %></span>
                    <% end %>
                </div>
                <div class="text-xs text-gray-400 mt-1">
                    <a href="/?roe_5y_avg_ge_12=1" class="<%= @stock.roe_5y_avg_ge_12 ? 'text-green-600' : 'text-gray-400' %> hover:underline">近5年均值≥12%</a>
                    <span class="mx-1 text-gray-300">|</span>
                    <a href="/?roe_5y_min_ge_8=1" class="<%= @stock.roe_5y_min_ge_8 ? 'text-green-600' : 'text-gray-400' %> hover:underline">近5年最低≥8%</a>
                </div>
                <div class="text-xs text-gray-400 mt-1">近5年均值: <%= @roe_5y_avg ? format_percent(@roe_5y_avg) : '-' %> / 最低: <%= @roe_5y_min ? format_percent(@roe_5y_min) : '-' %></div>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">总股本</div>
                <div class="text-base font-semibold text-gray-800"><%= format_shares(@stock.total_shares) %></div>
                <div class="text-xs text-gray-400 mt-1">
                    <a href="/?only_div5y=1" class="<%= @stock.has_dividend_5y ? 'text-green-600' : 'text-gray-400' %> hover:underline">连续5年分红</a>
                </div>
            </div>
            <div class="p-3 bg-gray-50 rounded-lg">
                <div class="text-gray-500 text-xs mb-1">中国10年期国债</div>
                <div class="text-base font-semibold text-gray-800"><%= format_percent(@cn_10y&.yield_pct) %></div>
                <div class="text-xs text-gray-400 mt-1"><%= @cn_10y&.date %></div>
            </div>
        </div>
        
        <!-- 滚动指标概览 -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 pt-6 border-t border-gray-100">
            <% [["30d", @stock.pos_30d], ["1y", @stock.pos_1y], ["3y", @stock.pos_3y], ["5y", @stock.pos_5y]].each do |label, pos| %>
                <div class="text-center">
                    <div class="text-gray-400 text-xs uppercase mb-1"><%= label %> 分位</div>
                    <div class="text-lg font-semibold <%= position_color(pos) %>">
                        <%= format_ratio_percent(pos) %>
                    </div>
                </div>
            <% end %>
        </div>
    </div>

    <!-- 价格图表 -->
    <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path></svg>
            10年历史价格走势 (收盘价)
        </h2>
        <div class="h-[400px]">
            <canvas id="priceChart"></canvas>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8L13 15M3 17V7a2 2 0 012-2h6"></path></svg>
            ROE（加权）年报（全量）
        </h2>
        <div class="h-[240px] mb-4">
            <canvas id="roeChart"></canvas>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-gray-50 text-gray-700 text-sm uppercase">
                        <th class="p-3 border-b">年份</th>
                        <th class="p-3 border-b text-right">ROE(加权)</th>
                        <th class="p-3 border-b text-center">报告期</th>
                        <th class="p-3 border-b text-center">公告日期</th>
                    </tr>
                </thead>
                <tbody class="text-sm text-gray-600">
                    <% @roe_annual_rows.each do |row| %>
                        <tr class="hover:bg-gray-50 border-b border-gray-50">
                            <td class="p-3"><%= row.report_date&.year %></td>
                            <td class="p-3 text-right"><%= format_percent(row.roe_jq) %></td>
                            <td class="p-3 text-center text-gray-400"><%= row.report_date %></td>
                            <td class="p-3 text-center text-gray-400"><%= row.notice_date || '-' %></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3v18m0 0l-4-4m4 4l4-4M4 7h14a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V9a2 2 0 012-2z"></path></svg>
            每股现金分红（近10年）
        </h2>
        <div class="h-[260px]">
            <canvas id="dividendChart"></canvas>
        </div>
    </div>

    <!-- 分红列表 -->
    <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold text-gray-800 mb-4 flex items-center">
            <svg class="w-5 h-5 mr-2 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            历史分红方案
        </h2>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-gray-50 text-gray-700 text-sm uppercase">
                        <th class="p-3 border-b">报告期</th>
                        <th class="p-3 border-b">分红方案</th>
                        <th class="p-3 border-b text-right">每股派现(元)</th>
                        <th class="p-3 border-b text-right font-bold text-green-700">当时股息率</th>
                        <th class="p-3 border-b text-center">公告日期</th>
                    </tr>
                </thead>
                <tbody class="text-sm text-gray-600">
                    <% @dividends.each do |div| %>
                        <tr class="hover:bg-gray-50 border-b border-gray-50">
                            <td class="p-3"><%= div.report_date %></td>
                            <td class="p-3 text-gray-800"><%= div.plan_description %></td>
                            <td class="p-3 text-right"><%= format_decimal(div.cash_dividend, 4) %></td>
                            <td class="p-3 text-right font-bold text-green-600"><%= format_percent(div.dividend_yield) %></td>
                            <td class="p-3 text-center text-gray-400"><%= div.notice_date || '-' %></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const priceCanvas = document.getElementById('priceChart');
    if (priceCanvas) {
    const ctx = priceCanvas.getContext('2d');
    
    const chartData = {
        labels: [<%= @price_histories.map { |ph| "'#{ph.date}'" }.join(',') %>],
        datasets: [
            {
                label: '收盘价 (¥)',
                data: [<%= @price_histories.map { |ph| ph.close.to_f }.join(',') %>],
                borderColor: 'rgb(59, 130, 246)',
                backgroundColor: 'rgba(59, 130, 246, 0.1)',
                borderWidth: 2,
                pointRadius: 0,
                fill: true,
                tension: 0.1,
                yAxisID: 'y'
            },
            {
                label: 'PB',
                data: [<%= @price_histories.map { |ph| ph.pb.nil? ? 'null' : ph.pb.to_f }.join(',') %>],
                borderColor: 'rgb(16, 185, 129)',
                backgroundColor: 'rgba(16, 185, 129, 0.1)',
                borderWidth: 1,
                pointRadius: 0,
                fill: false,
                tension: 0.1,
                yAxisID: 'y1'
            },
            {
                label: 'PE(TTM)',
                data: [<%= @price_histories.map { |ph| ph.pe_ttm.nil? ? 'null' : ph.pe_ttm.to_f }.join(',') %>],
                borderColor: 'rgb(234, 179, 8)',
                backgroundColor: 'rgba(234, 179, 8, 0.1)',
                borderWidth: 1,
                pointRadius: 0,
                fill: false,
                tension: 0.1,
                yAxisID: 'y2'
            }
        ]
    };

    new Chart(ctx, {
        type: 'line',
        data: chartData,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: {
                intersect: false,
                mode: 'index',
            },
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    padding: 12,
                    backgroundColor: 'rgba(255, 255, 255, 0.9)',
                    titleColor: '#1f2937',
                    bodyColor: '#4b5563',
                    borderColor: '#e5e7eb',
                    borderWidth: 1,
                    displayColors: false
                }
            },
            scales: {
                x: {
                    grid: {
                        display: false
                    },
                    ticks: {
                        maxTicksLimit: 12
                    }
                },
                y: {
                    grid: {
                        color: '#f3f4f6'
                    },
                    ticks: {
                        callback: function(value) {
                            return '¥' + value;
                        }
                    }
                },
                y1: {
                    position: 'right',
                    grid: {
                        drawOnChartArea: false
                    },
                    ticks: {
                        callback: function(value) {
                            return value;
                        }
                    }
                },
                y2: {
                    position: 'right',
                    grid: {
                        drawOnChartArea: false
                    },
                    ticks: {
                        callback: function(value) {
                            return value;
                        }
                    }
                }
            }
        }
    });
    }

    const roeCtx = document.getElementById('roeChart');
    if (roeCtx) {
        const roeSeries = [<%= @roe_annual_rows.map { |r| r.roe_jq.to_f }.join(',') %>];
        const roeYears = [<%= @roe_annual_rows.map { |r| "'#{r.report_date&.year}'" }.join(',') %>];
        const roeMa5 = roeSeries.map((_, i) => {
            if (i < 4) return null;
            const window = roeSeries.slice(i - 4, i + 1);
            const sum = window.reduce((acc, v) => acc + v, 0);
            return sum / window.length;
        });
        new Chart(roeCtx.getContext('2d'), {
            type: 'bar',
            data: {
                labels: roeYears,
                datasets: [{
                    label: 'ROE(加权) %',
                    data: roeSeries,
                    backgroundColor: 'rgba(16, 185, 129, 0.25)',
                    borderColor: 'rgb(16, 185, 129)',
                    borderWidth: 1
                }, {
                    type: 'line',
                    label: 'MA5',
                    data: roeMa5,
                    borderColor: 'rgb(59, 130, 246)',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    borderWidth: 2,
                    pointRadius: 0,
                    tension: 0.2,
                    spanGaps: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: true } },
                scales: {
                    x: { grid: { display: false } },
                    y: {
                        grid: { color: '#f3f4f6' },
                        ticks: { callback: function(v) { return v + '%'; } }
                    }
                }
            }
        });
    }

    const divCtx = document.getElementById('dividendChart');
    if (divCtx) {
        new Chart(divCtx.getContext('2d'), {
            type: 'bar',
            data: {
                labels: [<%= @annual_dividends.map { |x| "'#{x[:year]}'" }.join(',') %>],
                datasets: [{
                    label: '每股现金分红(元)',
                    data: [<%= @annual_dividends.map { |x| x[:cash].to_f }.join(',') %>],
                    backgroundColor: 'rgba(59, 130, 246, 0.18)',
                    borderColor: 'rgb(59, 130, 246)',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } },
                    y: {
                        grid: { color: '#f3f4f6' },
                        ticks: { callback: function(v) { return v; } }
                    }
                }
            }
        });
    }
</script>
